# Server
PORT=5000

# Groq AI API Key - Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret - Change this to a random string
JWT_SECRET=your_jwt_secret_here

# Class credentials - Add as many classes as needed
CLASS_1_NAME=Class 10
CLASS_1_PASSWORD=class10pass
CLASS_2_NAME=Class 11 Science
CLASS_2_PASSWORD=class11scipass
CLASS_3_NAME=Class 12 Commerce
CLASS_3_PASSWORD=class12compass
